# Configuration du Widget Martinique Estimator
# Copiez ce fichier vers .env.local et ajustez les valeurs

# URL de votre webhook n8n (OBLIGATOIRE)
NEXT_PUBLIC_API_BASE=https://votre-n8n-instance.com/webhook

# Configuration optionnelle pour les services backend
# estimate-api (si vous déployez séparément du workflow n8n)
ESTIMATE_API_URL=http://localhost:8080

# MCP Server configuration (pour le workflow n8n)
MCP_SERVER_PATH=/mcp-code/dist/index.js
MCP_IGNORE_ROBOTS=true

# Configuration Cloudflare Pages
# Ces variables sont automatiquement définies par Cloudflare
# CLOUDFLARE_API_TOKEN=your_token_here
# CLOUDFLARE_ACCOUNT_ID=your_account_id

# Configuration pour le développement local
# Port du serveur de développement Next.js
PORT=9002

# Niveau de logging (development uniquement)
LOG_LEVEL=info

# Redis configuration (pour le cache backend)
REDIS_URL=redis://localhost:6379
REDIS_TTL=86400

# Configuration MCP Server avancée
MCP_RATE_LIMIT=3
MCP_TIMEOUT=30000
MCP_RETRY_ATTEMPTS=2